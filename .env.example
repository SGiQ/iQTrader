# ===== API (apps/api) — set these on Railway =====
DATABASE_URL=postgresql://user:pass@localhost:5432/sgiqtrader

# Alpaca — use a SEPARATE Alpaca account from DCATradeBot (one paper account
# per Alpaca login; the sgiqbusiness account's paper env is occupied).
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Claude API — tutor engine
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Shared secret between web app and API. Generate: openssl rand -hex 32
API_KEY=

API_PORT=4100
WORKER_TIMEZONE=America/New_York

# ===== Web (apps/web) — set these on Vercel =====
# API_URL=https://<railway-domain>
# API_KEY=<same as above>
# APP_PASSWORD=<login password for the web UI>
